{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/minipower-token-guard.ps1",
        "timeout": 10
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/minipower-auto-routing.ps1",
        "timeout": 10
      },
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/minipower-decision-staleness.ps1",
        "timeout": 10
      }
    ],
    "beforeReadFile": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/minipower-token-guard-read.ps1",
        "matcher": "Read"
      }
    ]
  }
}
