{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/check-prompt-scope.sh",
        "timeout": 5
      },
      {
        "command": ".cursor/hooks/check-doc-phase.sh",
        "timeout": 5
      }
    ],
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/limit-reads.sh",
        "matcher": "Read"
      }
    ]
  }
}
