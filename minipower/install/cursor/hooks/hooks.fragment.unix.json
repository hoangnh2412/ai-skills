{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": ".cursor/hooks/minipower-token-guard.sh",
        "timeout": 5
      },
      {
        "command": ".cursor/hooks/minipower-auto-routing.sh",
        "timeout": 5
      }
    ],
    "beforeReadFile": [
      {
        "command": ".cursor/hooks/minipower-token-guard-read.sh",
        "matcher": "Read"
      }
    ]
  }
}
