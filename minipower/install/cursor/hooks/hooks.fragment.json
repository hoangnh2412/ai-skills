{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/skills/minipower/hooks/bin/token-guard.js",
        "timeout": 5
      },
      {
        "command": "node .cursor/skills/minipower/hooks/bin/auto-routing.js",
        "timeout": 5
      },
      {
        "command": "node .cursor/skills/minipower/hooks/bin/profile-guard.js",
        "timeout": 5
      },
      {
        "command": "node .cursor/skills/minipower/hooks/bin/decision-staleness.js",
        "timeout": 10
      }
    ],
    "beforeReadFile": [
      {
        "command": "node .cursor/skills/minipower/hooks/bin/token-guard-read.js",
        "matcher": "Read"
      }
    ]
  }
}
