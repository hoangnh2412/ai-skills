GRAFANA_URL=http://localhost:3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=Admin@123
PROMETHEUS_URL=http://localhost:9090

# Dashboard variables — tên biến khác nhau theo từng dashboard.
# Chạy: node list-dashboard-vars.js --uid <uid> để xem tên thực tế.
# Cách 1: nhiều biến, phân cách bằng dấu phẩy
# DASHBOARD_VARS=exported_job=MyApp,exported_instance=localhost
# Cách 2: từng biến (tên sau DASHBOARD_VAR_ = name trong Grafana)
# DASHBOARD_VAR_job=my-service
# DASHBOARD_VAR_service_name=orders-api

# Time range — dùng một trong hai cách:
# Cách 1: tương điện (giờ gần nhất)
HOURS=24
# Cách 2: tuyệt đối (ISO8601 hoặc Unix)
# START=2026-06-12T00:00:00Z
# END=2026-06-13T00:00:00Z
