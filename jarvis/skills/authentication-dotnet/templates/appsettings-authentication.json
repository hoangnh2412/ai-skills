{
  "Authentication": {
    "Type": "ApiKey",
    "DefaultAuthenticateScheme": "Composite",
    "DefaultChallengeScheme": "Composite",
    "Schemes": {
      "Jwt": { "Enabled": false },
      "ApiKey": { "Enabled": true },
      "Basic": { "Enabled": true }
    },
    "PasswordPolicy": {
      "MinLength": 8,
      "RequireDigit": true,
      "RequireUppercase": false,
      "RequireLowercase": true,
      "RequireNonAlphanumeric": false
    },
    "Jwt": {
      "Bearer": {
        "Authority": "",
        "Audience": "",
        "RequireHttpsMetadata": true,
        "IssuerSigningKeys": [],
        "ValidateAudience": true,
        "ValidAudiences": [],
        "ValidateIssuerSigningKey": true,
        "ValidateIssuer": false,
        "ValidIssuers": [],
        "MaxExpireMinutes": 0
      }
    },
    "ApiKey": {
      "Default": {
        "KeyName": "X-API-KEY",
        "Key": ""
      },
      "Integration": {
        "KeyName": "X-API-KEY",
        "Key": ""
      }
    },
    "Basic": {
      "Default": {
        "Realm": "Jarvis API",
        "Users": {
          "demo": {
            "Password": "",
            "Roles": [ "User" ]
          }
        }
      }
    }
  }
}
