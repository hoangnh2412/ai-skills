GRAFANA_URL=https://monitor-mpetro.minvoice.com.vn
GRAFANA_USER=admin
GRAFANA_PASSWORD=

# Copy file này thành .env — tools tự load tools/.env khi chạy (không cần npm/dotenv).

# Loki datasource UID (từ Grafana Explore URL hoặc Settings → Data sources)
LOKI_DATASOURCE_UID=b2e2e9f6-64bb-401c-8694-29ad093e15cc

# Tempo datasource UID
TEMPO_DATASOURCE_UID=

# Tempo search defaults
# TEMPO_LIMIT=20
# TEMPO_TRACEQL={ resource.service.name = "Minvoice.mEmailConsumer.Production" }
# TEMPO_TAGS=service.name=Minvoice.mEmailConsumer.Production

# Time range — dùng một trong hai cách:
# Cách 1: tương đối (phút gần nhất)
MINUTES=30
# Cách 2: tuyệt đối (ISO8601 hoặc Unix)
# START=2026-06-24T00:00:00Z
# END=2026-06-24T01:00:00Z

# LogQL mặc định (có thể override bằng --query / --explore-url)
# LOGQL={job="Minvoice.mEmailConsumer.Production"} |= `correlation-id` | json
